# JWT
JWT_SECRET=change-me-in-production

# CORS — comma-separated origins (use * to allow all during local dev)
ALLOWED_ORIGINS=*

# Discord OAuth2 (optional — leave blank to disable Discord login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Setup endpoint secret (POST /api/setup)
SETUP_SECRET=change-me-in-production

# Listing expiry in days (default: 30)
LISTING_EXPIRY_DAYS=30
